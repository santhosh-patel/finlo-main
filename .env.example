# Copy to `.env` for local dev. Never commit `.env`.

# Supabase (Vite exposes `VITE_*` to the browser — use publishable key only.)
VITE_SUPABASE_PROJECT_ID="your-project-id"
VITE_SUPABASE_PUBLISHABLE_KEY="your-publishable-anon-key"
VITE_SUPABASE_URL="https://your-project.supabase.co"

# Do NOT put server-only secrets in VITE_* variables.
# For Edge Functions set these in Supabase Dashboard → Edge Functions → Secrets:
# GEMINI_API_KEY=
# GROQ_API_KEY=
# LOVABLE_API_KEY=
# ALLOWED_ORIGINS=https://yourapp.com,http://localhost:8080
# CRON_SECRET=long-random-string
# SEED_ADMINS=[{"email":"admin@example.com","password":"StrongP@ss1","name":"Admin","role":"admin"}]
