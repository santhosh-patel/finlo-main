# Copy to `.env` for local dev. Never commit `.env`.

# Supabase (Vite exposes `VITE_*` to the browser — use publishable key only.)
VITE_SUPABASE_PROJECT_ID="your-project-id"
VITE_SUPABASE_PUBLISHABLE_KEY="your-publishable-anon-key"
VITE_SUPABASE_URL="https://your-project.supabase.co"

# Do NOT put server-only secrets in VITE_* variables.
# For Edge Functions set these in Supabase Dashboard → Edge Functions → Secrets:
# GEMINI_API_KEY=
# GROQ_API_KEY=
# LOVABLE_API_KEY=
# ALLOWED_ORIGINS=https://yourapp.com,http://localhost:8080
# CRON_SECRET=long-random-string
# ── Admin seed (`seed-admin` Edge Function secrets in Supabase Dashboard) ──
# Recommended initial admin: admin@finlo.com — passwords only in Dashboard secrets, never in git.
# Dashboard secrets: SEED_ADMINS (JSON array), SEED_BOOTSTRAP_SECRET (long random string).
# Local `npm run seed-admin`: copy the Dashboard `SEED_BOOTSTRAP_SECRET` into `.env`:
# SEED_BOOTSTRAP_SECRET=your-bootstrap-secret-matching-dashboard
# Or: npm run seed-admin -- --bootstrap-secret=your-bootstrap-secret-matching-dashboard
# SEED_ADMINS=[{"email":"admin@finlo.com","password":"YOUR_SECURE_PASSWORD_HERE","name":"Admin","role":"admin"}]
